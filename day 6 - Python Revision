# OOP
class Student:

    def __init__(self, name, domain):
        self.name = name
        self.domain = domain

    def display(self):
        print(f"\nName   : {self.name}")
        print(f"Domain : {self.domain}")


student1 = Student("Pankaj", "Generative AI")
student1.display()
